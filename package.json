    "better-sqlite3": "^12.10.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
